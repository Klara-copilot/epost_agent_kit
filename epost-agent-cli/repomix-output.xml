  '.epostrc.yml',
  'epost.config.js',
  'epost.config.cjs',
  'epost.config.mjs'
];

/**
 * File patterns that should NEVER be modified by epost-kit
 */
export const PROTECTED_FILE_PATTERNS = [
  '.git/**',
  'node_modules/**',
  '.env',
  '.env.*',
  '*.key',
  '*.pem',
  '*.p12',
  '*.pfx'
];

/**
