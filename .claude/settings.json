{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint -- --fix 2>/dev/null || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run build 2>/dev/null || true",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Verify all requested tasks are complete. If any remain unfinished, respond with {\"ok\": false, \"reason\": \"remaining work description\"}."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: This is epost_agent_kit. Use epost agents for all tasks. Check CLAUDE.md for conventions.'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "mcp__xcodebuildmcp__*"
    ]
  },
  "env": {
    "CLAUDEKIT_AGENT_STYLE": "full"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.cjs",
    "padding": 0
  }
}
