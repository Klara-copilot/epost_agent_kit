---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const workflows = [
  {
    slug: 'automated-code-audit',
    title: 'Automated Code Audit',
    description: 'Agents watch for changes, audit quality, security, and a11y — then suggest or apply fixes automatically.',
    badge: 'Quality',
    color: '#eab308',
    agents: ['code-reviewer', 'a11y-specialist', 'debugger', 'git-manager'],
    status: 'Available',
  },
  {
    slug: 'po-to-prototype',
    title: 'PO-to-Prototype Pipeline',
    description: 'Product Owner describes a feature in plain language. Agents plan, prototype, audit, fix, and deliver a working branch.',
    badge: 'End-to-End',
    color: '#3b82f6',
    agents: ['planner', 'fullstack-developer', 'code-reviewer', 'tester', 'git-manager'],
    status: 'Available',
  },
  {
    slug: 'brainstorming',
    title: 'Brainstorming Flow',
    description: 'From idea to spike — brainstormer generates options, planner evaluates feasibility, developer creates a proof-of-concept.',
    badge: 'Ideation',
    color: '#a855f7',
    agents: ['brainstormer', 'planner', 'fullstack-developer', 'muji'],
    status: 'Available',
  },
  {
    slug: 'cross-branch-fixes',
    title: 'Cross-Branch Fix Propagation',
    description: 'Fix a bug once. Agents detect the same pattern in other branches and apply the fix — or open PRs for review.',
    badge: 'Maintenance',
    color: '#ef4444',
    agents: ['debugger', 'code-reviewer', 'git-manager'],
    status: 'Planned',
  },
  {
    slug: 'continuous-quality',
    title: 'Continuous Quality Loop',
    description: 'Agents monitor code health metrics — coverage, a11y score, bundle size, lint — and proactively fix regressions.',
    badge: 'CI/CD',
    color: '#06b6d4',
    agents: ['tester', 'a11y-specialist', 'code-reviewer', 'git-manager'],
    status: 'Planned',
  },
  {
    slug: 'development-dashboard',
    title: 'Development Dashboard',
    description: 'Automatic progress tracking from agent outputs — plan status, velocity, quality metrics, activity logs. Zero manual reporting.',
    badge: 'Tracking',
    color: '#22c55e',
    agents: ['project-manager', 'journal-writer', 'planner'],
    status: 'Planned',
  },
];
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Automation workflows powered by multi-agent orchestration" />
    <title>Workflows — epost_agent_kit</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◈</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-950 text-slate-300 font-body antialiased overflow-x-hidden">
    <Nav />
    <main class="pt-14">
      <section class="py-20 px-6 border-b border-zinc-800/60 relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_0%,rgba(52,211,153,0.06),transparent)]"></div>
        <div class="relative max-w-5xl mx-auto">
          <a href="/" class="inline-flex items-center gap-1.5 text-xs font-mono text-slate-600 hover:text-slate-400 transition-colors mb-6">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Home
          </a>
          <div class="section-label">Automation</div>
          <h1 class="font-display text-4xl sm:text-5xl font-bold text-white leading-tight mb-6">
            Workflow Automation
          </h1>
          <p class="text-lg text-slate-400 max-w-2xl leading-relaxed">
            Real automation scenarios where multi-agent orchestration replaces manual processes. Each workflow chains specialized agents into end-to-end pipelines.
          </p>
        </div>
      </section>

      <section class="py-16 px-6">
        <div class="max-w-5xl mx-auto grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {workflows.map((wf) => (
            <a href={`/workflows/${wf.slug}`} class="card-surface p-6 hover:border-zinc-700 transition-all duration-200 group hover:-translate-y-0.5 flex flex-col">
              <div class="flex items-center justify-between mb-4">
                <span class="text-xs font-mono px-2 py-0.5 rounded border" style={`background: ${wf.color}10; border-color: ${wf.color}30; color: ${wf.color};`}>
                  {wf.badge}
                </span>
                <span class={`text-xs font-mono ${wf.status === 'Available' ? 'text-emerald-400' : 'text-slate-600'}`}>
                  {wf.status}
                </span>
              </div>
              <h3 class="font-display font-semibold text-white text-lg mb-2 group-hover:text-emerald-400 transition-colors">
                {wf.title}
              </h3>
              <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-4">
                {wf.description}
              </p>
              <div class="flex flex-wrap gap-1.5 pt-3 border-t border-zinc-800/60">
                {wf.agents.map((a) => (
                  <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-zinc-800 text-slate-600">
                    {a}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
