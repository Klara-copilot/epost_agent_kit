---
const pairs = [
  {
    problem: 'Context switching mid-task',
    solution: 'Smart routing that detects intent, platform, and context — no config, no flags needed',
    icon: '⇄',
  },
  {
    problem: 'Forgotten conventions',
    solution: '65+ skills loaded on-demand per task — patterns always available without bloating context',
    icon: '◈',
  },
  {
    problem: 'Manual quality checks',
    solution: 'Two-stage review gates: code reviewer then a11y specialist catch issues before merge',
    icon: '◉',
  },
  {
    problem: 'Platform context loss',
    solution: '4-platform support — same workflow, correct conventions for web, iOS, Android, backend',
    icon: '◎',
  },
];
---
<section class="py-24 px-6 bg-slate-950">
  <div class="max-w-5xl mx-auto">
    <div class="section-label">The Problem</div>
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-16">
      Development friction, systematically eliminated.
    </h2>

    <div class="grid sm:grid-cols-2 gap-6">
      {pairs.map((pair) => (
        <div class="card-surface p-6 group hover:border-zinc-700 transition-colors">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-slate-600 font-mono text-xl flex-shrink-0">{pair.icon}</div>
            <div>
              <div class="text-xs font-mono text-red-400/70 uppercase tracking-wider mb-1">Before</div>
              <p class="text-slate-400 text-sm">{pair.problem}</p>
            </div>
          </div>
          <div class="h-px bg-zinc-800 mb-4"></div>
          <div class="flex items-start gap-4">
            <div class="text-emerald-400 font-mono text-xl flex-shrink-0">→</div>
            <div>
              <div class="text-xs font-mono text-emerald-400/70 uppercase tracking-wider mb-1">After</div>
              <p class="text-slate-300 text-sm">{pair.solution}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
