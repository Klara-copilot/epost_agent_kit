---
---
<section id="getting-started" class="py-24 px-6 bg-zinc-900/50 border-t border-zinc-800/60">
  <div class="max-w-5xl mx-auto">
    <div class="section-label">Install</div>
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
      Up in two commands.
    </h2>
    <p class="text-slate-400 mb-12 max-w-2xl">
      Install the CLI globally, then run <code class="font-mono text-emerald-400 text-sm bg-zinc-800 px-1.5 py-0.5 rounded">epost-kit init</code> in your project. Agents and skills are wired automatically.
    </p>

    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <!-- Install steps -->
      <div class="space-y-4">
        <!-- Step 1 -->
        <div class="card-surface overflow-hidden">
          <div class="px-4 py-2 bg-zinc-800/40 border-b border-zinc-800 flex items-center gap-2">
            <span class="w-5 h-5 rounded-full border border-emerald-400/40 flex items-center justify-center text-emerald-400 font-mono text-xs">1</span>
            <span class="text-xs text-slate-500">Install the CLI</span>
          </div>
          <div class="p-4 font-mono text-sm">
            <span class="text-slate-500">$</span>
            <span class="text-slate-200 ml-2">npm install -g epost-kit</span>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="card-surface overflow-hidden">
          <div class="px-4 py-2 bg-zinc-800/40 border-b border-zinc-800 flex items-center gap-2">
            <span class="w-5 h-5 rounded-full border border-emerald-400/40 flex items-center justify-center text-emerald-400 font-mono text-xs">2</span>
            <span class="text-xs text-slate-500">Init your project</span>
          </div>
          <div class="p-4 font-mono text-sm">
            <span class="text-slate-500">$</span>
            <span class="text-slate-200 ml-2">epost-kit init</span>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="card-surface overflow-hidden">
          <div class="px-4 py-2 bg-zinc-800/40 border-b border-zinc-800 flex items-center gap-2">
            <span class="w-5 h-5 rounded-full border border-emerald-400/40 flex items-center justify-center text-emerald-400 font-mono text-xs">3</span>
            <span class="text-xs text-slate-500">Start working</span>
          </div>
          <div class="p-4 font-mono text-sm text-emerald-400">
            fix the login page
          </div>
        </div>
      </div>

      <!-- First interaction -->
      <div class="card-surface overflow-hidden">
        <div class="flex items-center gap-1.5 px-4 py-3 bg-zinc-800/60 border-b border-zinc-700/50">
          <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
          <span class="ml-2 text-xs text-slate-600 font-mono">your first session</span>
        </div>
        <div class="p-5 font-mono text-xs leading-loose">
          <p class="text-emerald-400 mb-1">&gt; plan a notification feature</p>
          <p class="text-slate-600">Checking git state...</p>
          <p class="text-slate-600">Detected: multi-platform, Plan intent</p>
          <p class="text-slate-600">Loading: plan, knowledge-retrieval</p>
          <p class="text-slate-600">Dispatching epost-planner...</p>
          <br/>
          <p class="text-slate-300">Phase 1 — Backend endpoints</p>
          <p class="text-slate-500">  - POST /notifications/subscribe</p>
          <p class="text-slate-500">  - GET  /notifications/preferences</p>
          <br/>
          <p class="text-slate-300">Phase 2 — iOS foreground handling</p>
          <p class="text-slate-500">  - UNUserNotificationCenter delegate</p>
          <p class="text-slate-500">  - Swift 6 actor isolation</p>
          <br/>
          <p class="text-slate-300">Phase 3 — Web notification center</p>
          <p class="text-slate-500">  - NotificationCenter.tsx component</p>
          <p class="text-slate-500">  - Redux slice + SSE connection</p>
          <br/>
          <p class="text-slate-600">Plan saved → plans/260312-0900-notifications/</p>
          <p class="text-emerald-400/60">&gt; _</p>
        </div>
      </div>
    </div>

    <!-- GitHub CTA -->
    <div class="mt-16 text-center">
      <a
        href="https://github.com/Klara-copilot/epost-agent-kit-cli"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-emerald-400 text-slate-950 font-display font-bold text-base hover:bg-emerald-300 transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
        </svg>
        Star on GitHub
      </a>
      <p class="text-slate-600 text-sm mt-4 font-mono">npm install -g epost-kit</p>
    </div>
  </div>
</section>
