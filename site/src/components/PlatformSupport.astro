---
import { platforms } from '../data/platforms';
---
<section class="py-24 px-6 bg-zinc-900/50 border-y border-zinc-800/60">
  <div class="max-w-5xl mx-auto">
    <div class="section-label">Platform Coverage</div>
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
      Four platforms. Same discipline.
    </h2>
    <p class="text-slate-400 mb-12 max-w-2xl">
      Platform detected from file extensions. Correct skills loaded. No configuration needed.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {platforms.map((platform) => (
        <div class={`card-surface p-5 ${platform.borderColor} hover:border-opacity-60 transition-colors`}>
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center text-lg mb-4 font-mono"
            style={`background: ${platform.color}15; color: ${platform.color};`}
          >
            {platform.icon}
          </div>
          <h3 class="font-display font-semibold text-white mb-3">{platform.name}</h3>
          <ul class="space-y-1.5">
            {platform.stack.map((item) => (
              <li class="text-xs text-slate-500 flex items-start gap-1.5">
                <span class="text-slate-700 mt-0.5 flex-shrink-0">·</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
