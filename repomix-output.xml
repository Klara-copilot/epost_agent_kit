    skill: '.cursor/commands',
    command: '.cursor/commands',
    rule: '.cursor/rules',
    workflow: '.cursor/rules'
  },
  copilot: {
    agent: '.github/agents',
    skill: '.github/prompts',
    command: '.github/prompts',
    rule: '.github/instructions',
    workflow: '.github/workflows'
  }
};
```

