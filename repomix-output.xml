 * Key scenarios:
 * - resolveRulesPath() checks rules/ first
 * - Falls back to workflows/ if rules/ not found
 * - resolveWorkflowPath alias works
 * - Both directories: rules/ wins
 */

const { describe, it, before, after } = require('node:test');
