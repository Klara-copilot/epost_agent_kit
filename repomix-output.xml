          `Should export ${exportName}`);
      }
    });

  });

  describe('CLAUDE.md reference resolution', () => {
    let tempDir;
    let originalCwd;

    before(() => {
      originalCwd = process.cwd();
    });

    after(() => {
      process.chdir(originalCwd);
