      failed++;
    }
  } catch (error) {
    // Exit 2 = BLOCKED
    const actual = error.status === 2 ? 'BLOCKED' : `ERROR(${error.status})`;
    const success = actual === scenario.expected;
    if (success) {
      console.log(`\x1b[32m✓\x1b[0m ${scenario.desc}: ${actual}`);
      passed++;
